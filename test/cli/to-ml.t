Annotated topology (functor-application mode)
  $ cat > annot_topo.fpp <<EOF
  > port P
  > active component Net { sync input port write: P }
  > active component Eth {
  >   output port net: P
  >   sync input port write: P
  > }
  > active component Ipv4 {
  >   output port eth: P
  >   @ ocaml.param
  >   sync input port cidr: P
  > }
  > instance net: Net base id 0x100
  > instance eth: Eth base id 0x200
  > instance ipv4: Ipv4 base id 0x300
  > topology Stack {
  >   instance net
  >   instance eth
  >   instance ipv4
  >   connections W {
  >     eth.net -> net.write
  >     ipv4.eth -> eth.write
  >   }
  > }
  > EOF
  $ ofpp to-ml annot_topo.fpp
  (* Module types generated by ofpp to-ml *)
  
  module type NET = sig
    type t
    val write : t -> unit
  end
  
  (* Generated by ofpp to-ml from topology Stack *)
  
  module Make
    (Net : NET) = struct
    module Eth = Eth.Make(Net)
    module Ipv4 = Ipv4.Make(Eth)
  
    type t = { net : Net.t; eth : Eth.t; ipv4 : Ipv4.t; }
  
    let w ~cidr net =
      let open Lwt.Syntax in
      let* eth = Eth.connect net in
      let* ipv4 = Ipv4.connect ~cidr eth in
      Lwt.return { net; eth; ipv4 }
  end

Bound leaf instance (@ ocaml.module)
  $ ofpp to-ml data/bound-leaf.fpp
  (* Generated by ofpp to-ml from topology T *)
  
  module Make = struct
    module Kv = Embedded_data
    module Srv = Srv.Make(Kv)
  
    type t = { kv : Kv.t; srv : Srv.t; }
  
    let w () =
      let open Lwt.Syntax in
      let* kv = Kv.connect () in
      let* srv = Srv.connect kv in
      Lwt.return { kv; srv }
  end




