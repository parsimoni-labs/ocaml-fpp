Simple topology (2 components, 1 connection)
  $ cat > topo.fpp <<EOF
  > port P
  > passive component Sensor {
  >   output port dataOut: P
  > }
  > passive component Logger {
  >   sync input port dataIn: P
  > }
  > instance sensor: Sensor base id 0x100
  > instance logger: Logger base id 0x200
  > topology System {
  >   instance sensor
  >   instance logger
  >   connections Data {
  >     sensor.dataOut -> logger.dataIn
  >   }
  > }
  > EOF
  $ ofpp to-ml topo.fpp
  (* Generated by ofpp to-ml from topology System *)
  
  module type LOGGER = sig
    type t
  end
  
  module type SENSOR = sig
    type t
  end
  
  module Make
    (Logger : LOGGER)
    (Sensor : sig include SENSOR val connect : Logger.t -> t end) = struct
    type t = { logger : Logger.t; sensor : Sensor.t; }
    let data logger =
      let sensor = Sensor.connect logger in
      { logger; sensor }
  end











Typed port topology
  $ cat > typed_topo.fpp <<EOF
  > port DataPort(value: U32) -> bool
  > passive component Producer {
  >   output port out: DataPort
  > }
  > passive component Consumer {
  >   sync input port in_: DataPort
  > }
  > instance producer: Producer base id 0x100
  > instance consumer: Consumer base id 0x200
  > topology App {
  >   instance producer
  >   instance consumer
  >   connections Main {
  >     producer.out -> consumer.in_
  >   }
  > }
  > EOF
  $ ofpp to-ml typed_topo.fpp
  (* Generated by ofpp to-ml from topology App *)
  
  module type CONSUMER = sig
    type t
  end
  
  module type PRODUCER = sig
    type t
  end
  
  module Make
    (Consumer : CONSUMER)
    (Producer : sig include PRODUCER val connect : Consumer.t -> t end) = struct
    type t = { consumer : Consumer.t; producer : Producer.t; }
    let main consumer =
      let producer = Producer.connect consumer in
      { consumer; producer }
  end











Filter by topology name
  $ cat > multi_topo.fpp <<EOF
  > port P
  > passive component A { output port out: P }
  > passive component B { sync input port in_: P }
  > instance a: A base id 0x100
  > instance b: B base id 0x200
  > topology T1 {
  >   instance a
  >   instance b
  >   connections C { a.out -> b.in_ }
  > }
  > topology T2 {
  >   instance a
  >   instance b
  >   connections C { a.out -> b.in_ }
  > }
  > EOF
  $ ofpp to-ml --topology T2 multi_topo.fpp
  (* Generated by ofpp to-ml from topology T2 *)
  
  module type B = sig
    type t
  end
  
  module type A = sig
    type t
  end
  
  module Make
    (B : B)
    (A : sig include A val connect : B.t -> t end) = struct
    type t = { b : B.t; a : A.t; }
    let c b =
      let a = A.connect b in
      { b; a }
  end











