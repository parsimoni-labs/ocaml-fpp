Simple topology (2 components, 1 connection)
  $ cat > topo.fpp <<EOF
  > port P
  > passive component Sensor {
  >   output port dataOut: P
  > }
  > passive component Logger {
  >   sync input port dataIn: P
  > }
  > instance sensor: Sensor base id 0x100
  > instance logger: Logger base id 0x200
  > topology System {
  >   instance sensor
  >   instance logger
  >   connections Data {
  >     sensor.dataOut -> logger.dataIn
  >   }
  > }
  > EOF
  $ ofpp to-ml topo.fpp
  [@@@ocamlformat "disable"]
  (* Generated by ofpp to-ml from topology System *)
  
  module Sensor = Sensor.Make(Logger)
  
  let data = lazy (
    let open Lwt.Syntax in
    let* logger = Logger.data_in () in
    Sensor.connect logger)













